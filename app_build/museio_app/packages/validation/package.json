{
  "name": "@museio/validation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./portfolio": {
      "types": "./src/portfolio.ts",
      "default": "./dist/portfolio.js"
    }
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" --ignore-pattern \"**/*.test.ts\" --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  }
}
