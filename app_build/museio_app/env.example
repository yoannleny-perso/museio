# Shared
NODE_ENV=development
# If local or CI runners inherit a custom CA override that breaks hosted Node fetch,
# launch verification commands with: env -u SSL_CERT_FILE <command>

# Public Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SUPABASE_URL=https://nbecxliasodiooacaiyd.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_J_c6YbJZcKv9CD_kOGzHvQ_SKeIa0Rd
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ENABLE_DEMO_AUTH=false

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_SUPABASE_URL=https://nbecxliasodiooacaiyd.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_J_c6YbJZcKv9CD_kOGzHvQ_SKeIa0Rd
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_ENABLE_DEMO_AUTH=false

# API
API_PORT=4000
# Railway sets PORT automatically. Leave API_PORT unset there unless overriding locally.
SUPABASE_URL=https://nbecxliasodiooacaiyd.supabase.co
SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_J_c6YbJZcKv9CD_kOGzHvQ_SKeIa0Rd
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SUPABASE_DB_HOST=your-hosted-postgres-host
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DB_PASSWORD=your-hosted-db-password
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Preview / staging rollout verification
PREVIEW_APP_URL=https://preview.museio.example
PREVIEW_API_URL=https://preview-api.museio.example/api
PREVIEW_SUPABASE_URL=https://your-project-ref.supabase.co
PREVIEW_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your_preview_key
PREVIEW_SUPABASE_SERVICE_ROLE_KEY=your-preview-service-role-key

# Preview deployment notes
# Vercel web should set NEXT_PUBLIC_APP_URL to the deployed Vercel preview URL.
# Railway API should set NEXT_PUBLIC_APP_URL to that same Vercel preview URL and
# CORS_ALLOWED_ORIGINS to a comma-separated allowlist that includes preview and future production web origins.
