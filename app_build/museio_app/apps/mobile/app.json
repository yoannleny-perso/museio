{
  "expo": {
    "name": "Museio",
    "slug": "museio",
    "scheme": "museio",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/brand/app-icon.png",
    "platforms": [
      "ios",
      "android"
    ],
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/brand/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#140f1d"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/app-icon.png",
        "backgroundColor": "#140f1d"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router"
    ]
  }
}
